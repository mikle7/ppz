[2C[3A[2D[3B[4A  [1mThe Lighthouse Keeper's Last Night[22m                                                                                                                                                                                [1B   [2B[38;5;246m❯ [39m[7m [27m               [175C                 
[38;5;244m────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────[39m
