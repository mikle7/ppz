# Local development env vars for ppz-server.
#
# Copy this file to .env.local (which is gitignored) and fill in:
#
#   cp .env.local.example .env.local
#   $EDITOR .env.local
#
# Then load + run:
#
#   set -a; . ./.env.local; set +a
#   make build && ./bin/ppz-server
#
# In production, these come from AWS Secrets Manager via the EC2
# instance role — see infra/secrets.go and infra/userdata.sh.tpl.

# ── GitHub OAuth (the "Pipes Local Dev" app) ───────────────────────
# From github.com/settings/applications/<app-id>
PPZ_GITHUB_CLIENT_ID=
PPZ_GITHUB_CLIENT_SECRET=

# ── Session signing ────────────────────────────────────────────────
# 32 random bytes, base64-url-encoded. Anything different from prod;
# rotate by changing the value (all sessions invalidate on rotation).
PPZ_SESSION_KEY=daxrEqzqQN4rCV70TBh0JHrfRTfovzizGuZkT/8VLhw

# ── Where the server thinks it lives ───────────────────────────────
# Used to construct OAuth callback URLs.
PPZ_BASE_URL=http://localhost:8080

# ── DB + listen ────────────────────────────────────────────────────
# Override only if you're not running the compose-stack postgres at
# the default port. Defaults pick up the hard-coded test creds.
# PPZ_DB_URL=postgres://postgres:ppz@localhost:5432/ppz?sslmode=disable
# PPZ_HTTP_ADDR=:8080
